PORT=8787
GCP_PROJECT_ID=your-project
GCS_BUCKET=your-bucket
MAGIC_LINK_SECRET=replace-with-random-string
# SERVICE_ACCOUNT_KEY_B64 should be a base64-encoded JSON service account key if you plan to generate real GCS signed URLs.
SERVICE_ACCOUNT_KEY_B64=base64-encoded-json
FRONTEND_URL=http://localhost:8000

# Optional SMTP for real magic links
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user
SMTP_PASS=pass
SMTP_FROM="Wednesdays <no-reply@example.com>"

# Optional request logging/rate limits
RATE_WINDOW_MS=60000
RATE_MAX=120
